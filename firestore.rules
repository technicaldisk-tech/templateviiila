rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Enable the server-side backend client to perform continuous backup & replication of the unified app state
    match /appState/database {
      allow read, write: if true;
    }
    // Prevent unauthorized accesses and secure the database globally by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
